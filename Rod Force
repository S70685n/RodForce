<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rod Force Calculator</title>

<style>
body {
    font-family: Arial, sans-serif;
    background: #000; /* BLACK BACKGROUND */
    margin: 0;
    padding: 20px;
    color: gold; /* GOLD TEXT */
}

.container {
    max-width: 500px;
    margin: auto;
    background: #111;
    padding: 20px;
    border-radius: 10px;
    box-shadow: 0 0 15px rgba(255,215,0,0.3);
}

.logo-container {
    text-align: center;
    margin-bottom: 20px;
}

.logo-container img {
    max-width: 160px;
}

h2 {
    text-align: center;
    color: gold;
}

label {
    font-weight: bold;
    display: block;
    margin-bottom: 6px;
}

input, select {
    width: 100%;
    padding: 12px;
    margin-bottom: 14px;
    font-size: 18px;
    border-radius: 6px;
    border: 1px solid gold;
    background: #000;
    color: gold;
}

button.calc {
    background: gold;
    color: black;
    border: none;
    width: 100%;
    padding: 14px;
    font-size: 18px;
    border-radius: 6px;
    cursor: pointer;
}

button.reset {
    background: #333;
    color: gold;
    border: none;
    width: 100%;
    padding: 14px;
    font-size: 18px;
    border-radius: 6px;
    margin-top: 10px;
    cursor: pointer;
}

.result {
    margin-top: 15px;
    font-size: 20px;
    font-weight: bold;
    text-align: center;
    color: gold;
}
</style>
</head>

<body>

<div class="container">

<div class="logo-container">
    <img src="https://eibach.com/storage/img/branding/eibach-main-red.png">
</div>

<h2>Rod Force</h2>

<label>Input Type</label>
<select id="rodType" onchange="updateRodUnits()">
    <option value="force">Rod Force to Nitrogen Pressure</option>
    <option value="pressure">Nitrogen Pressure to Rod Force</option>
</select>

<label>Unit (Verify whether Dyno test is in LBS or Newtons)</label>
<select id="rodUnit"></select>

<label>Value (Rod Force reading on Dyno or Nitrogen pressure specification)</label>
<input id="rodValue">

<label>Shaft Size</label>
<select id="shaft">
    <option value="0.196">1/2 inch</option>
    <option value="0.307" selected>5/8 inch</option>
    <option value="0.601">7/8 inch</option>
</select>

<button class="calc" onclick="calculateRod()">Calculate</button>
<button class="reset" onclick="resetRod()">Reset</button>

<div id="rodResult" class="result"></div>

</div>

<script>
function updateRodUnits(){
    rodUnit.innerHTML="";
    if(rodType.value==="force"){
        rodUnit.innerHTML =
            "<option value='lbs'>lbs</option>" +
            "<option value='N'>Newtons</option>";
    } else {
        rodUnit.innerHTML =
            "<option value='psi'>psi</option>" +
            "<option value='bar'>bar</option>";
    }
}

function calculateRod(){
    let v = parseFloat(rodValue.value);
    let f = parseFloat(shaft.value);

    if (isNaN(v)) {
        rodResult.innerText = "Enter a valid value";
        return;
    }

    if (rodType.value === "force") {
        if (rodUnit.value === "N") v *= 0.224809;

        let psi = v / f;
        let bar = psi / 14.5038;

        rodResult.innerText =
            `Pressure = ${psi.toFixed(2)} psi (${bar.toFixed(2)} bar)`;

    } else {
        let psi = (rodUnit.value === "bar") ? v * 14.5038 : v;

        let lbs = psi * f;
        let newtons = lbs / 0.224809;

        rodResult.innerText =
            `Force = ${lbs.toFixed(2)} lbs (${newtons.toFixed(2)} N)`;
    }
}

function resetRod(){
    rodValue.value="";
    rodResult.innerText="";
}

updateRodUnits();
</script>

</body>
</html>
